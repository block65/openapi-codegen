{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"printWidth": 80,
	"ignorePatterns": ["**/dist", "**/build", "**/node_modules", "**/.claude"],
	"sortPackageJson": {
		"sortScripts": true
	},
	"sortImports": {
		"newlinesBetween": false
	},
	"overrides": [
		{
			"files": ["*.jsonc"],
			"options": {
				"trailingComma": "none"
			}
		}
	]
}
