{
	"extends": ["@tsconfig/node24", "@tsconfig/strictest"],
	"compilerOptions": {
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"noPropertyAccessFromIndexSignature": false,
		"resolveJsonModule": true,
		"skipLibCheck": true
	},
	"include": ["./lib", "./bin", "__tests__"],
	"exclude": ["./dist", "node_modules"]
}
