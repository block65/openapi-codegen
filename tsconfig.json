{
	"extends": ["@tsconfig/node24", "@tsconfig/strictest"],
	"compilerOptions": {
		"composite": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"noPropertyAccessFromIndexSignature": false,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["./lib", "./bin"],
	"exclude": ["node_modules"]
}
